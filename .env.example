# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Gmail address that will send the alerts
GMAIL_ADDRESS=kalchikethan@gmail.com

# 16-character App Password from https://myaccount.google.com/apppasswords
# (NOT your regular Gmail password)
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Where you want the digest sent (can be the same as GMAIL_ADDRESS)
RECIPIENT_EMAIL=kalchikethan@gmail.com

# USAJobs API (free) — https://developer.usajobs.gov/APIRequest/Index
USAJOBS_API_KEY=your_usajobs_api_key_here
USAJOBS_EMAIL=kalchikethan@gmail.com
